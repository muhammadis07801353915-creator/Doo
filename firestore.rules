rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // ===============================================================
    // Assumed Data Model
    // ===============================================================
    // Collection: videos
    // Document ID: auto-generated
    // Fields:
    //   - filename: string (required)
    //   - url: string (required)
    //   - size: number (required)
    //   - createdAt: number (required)
    //   - uid: string (required)
    // ===============================================================

    function hasOnlyAllowedFields(fields) {
      return request.resource.data.keys().hasOnly(fields);
    }

    function isValidVideo(data) {
      return hasOnlyAllowedFields(['filename', 'url', 'size', 'createdAt', 'uid']) &&
             data.filename is string && data.filename.size() > 0 && data.filename.size() < 500 &&
             data.url is string && data.url.size() > 0 && data.url.size() < 2000 &&
             data.size is number && data.size > 0 &&
             data.createdAt is number &&
             data.uid is string;
    }

    match /videos/{videoId} {
      // Allow public read and write since the user requested no authentication
      allow read: if true;
      allow create: if isValidVideo(request.resource.data);
      allow update, delete: if true;
    }
  }
}
